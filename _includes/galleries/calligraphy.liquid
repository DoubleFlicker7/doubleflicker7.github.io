<section class="gallery-section-calligraphy gallery-section" aria-label="Gallery logos">
  <video class="gallery-bg-video" autoplay muted loop playsinline>
    <source src="{{ '/assets/img/galleries/background/Landscapes1.webm' | relative_url }}" type="video/webm">
  </video>
  <div class="text-section">
    <div class="serial-num">
      01
    </div>
    <div class="section-title">
      Calligraphy
    </div>
    <div class="description">
      Seek a moment of serenity.
    </div>
  </div>
  <div class="illustration-section">
    <div class="marquee-section">
      {% assign items = site.data.gallery_logos['column10'] %}
      <div class="logo-marquee-track-time" style="--direction:normal;">
        {% for logo in items %}
          <div
            class="logo-marquee-item-time"
            data-svg="{{ '/assets/img/galleries/calligraphy/' | append: logo.char | append: '.svg' | relative_url }}"
            style="--icon-url: url('{{ '/assets/img/galleries/calligraphy/' | append: logo.char | append: '.svg' | relative_url }}');"
            aria-hidden="true"
          ></div>
        {% endfor %}
        <div
          class="logo-marquee-item-seal"
          data-svg="{{ '/assets/img/galleries/calligraphy/Seal.svg' | relative_url }}"
          style="--icon-url: url('{{ '/assets/img/galleries/calligraphy/Seal.svg' | relative_url }}');"
          aria-hidden="true"
          ></div>
      </div>

      {% assign columns = "column9,column8,column7,column6,column5,column4,column3,column2" | split: "," %}
      {% for col in columns %}
        {% assign items = site.data.gallery_logos[col] %}
        <div class="logo-marquee logo-marquee-vertical">
          <div class="logo-marquee-track" style="--direction:normal;">
            {% for logo in items %}
              <div
                class="logo-marquee-item"
                data-svg="{{ '/assets/img/galleries/calligraphy/' | append: logo.char | append: '.svg' | relative_url }}"
                style="--icon-url: url('{{ '/assets/img/galleries/calligraphy/' | append: logo.char | append: '.svg' | relative_url }}');"
                aria-hidden="true"
              ></div>
            {% endfor %}
          </div>

          <div aria-hidden="true" class="logo-marquee-track" style="--direction:normal;">
            {% for logo in items %}
              <div
                class="logo-marquee-item"
                data-svg="{{ '/assets/img/galleries/calligraphy/' | append: logo.char | append: '.svg' | relative_url }}"
                style="--icon-url: url('{{ '/assets/img/galleries/calligraphy/' | append: logo.char | append: '.svg' | relative_url }}');"
                aria-hidden="true"
              ></div>
            {% endfor %}
          </div>
        </div>
      {% endfor %}

    </div>
  </div>

</section>

<script>
  async function getSvgSize(url) {
    const res = await fetch(url);
    const text = await res.text();

    const doc = new DOMParser().parseFromString(text, "image/svg+xml");
    const svg = doc.documentElement;

    let width = svg.getAttribute("width");
    let height = svg.getAttribute("height");

    if ((!width || !height) && svg.hasAttribute("viewBox")) {
      const parts = svg.getAttribute("viewBox").trim().split(/\s+/).map(Number);
      width = parts[2];
      height = parts[3];
    } else {
      width = parseFloat(width);
      height = parseFloat(height);
    }

    return { width, height };
  }

  async function applySvgHeight(el) {
    const url = el.dataset.svg;
    if (!url) return;

    try {
      const { width, height } = await getSvgSize(url);
      if (!width || !height) return;

      const targetWidth = el.getBoundingClientRect().width;
      if (!targetWidth) return;

      const targetHeight = targetWidth * height / width;
      el.style.height = `${targetHeight}px`;
    } catch (err) {
      console.error("Failed to load SVG size:", url, err);
    }
  }

  document.addEventListener("DOMContentLoaded", async () => {
    const items = document.querySelectorAll(
      ".logo-marquee-item, .logo-marquee-item-time, .logo-marquee-item-seal"
    );

    await Promise.all(
      Array.from(items).map(el => applySvgHeight(el))
    );
  });
</script>